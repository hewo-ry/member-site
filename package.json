{
    "name": "member-site",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint --flag unstable_native_nodejs_ts_config src --color",
        "check-types": "tsc --noEmit",
        "format": "prettier --write src .prettierrc *.config.{mts,ts} package.json tsconfig.json",
        "postinstall": "next telemetry disable"
    },
    "dependencies": {
        "better-auth": "^1.5.4",
        "next": "16.1.7",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@microsoft/eslint-formatter-sarif": "^3.1.0",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^24.12.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "babel-plugin-react-compiler": "1.0.0",
        "eslint": "^10.0.3",
        "eslint-config-next": "16.1.6",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "packageManager": "yarn@4.13.0"
}
